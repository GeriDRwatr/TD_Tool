#!/bin/sh
# AppImage entry point.
# PyInstaller's bootloader is self-sufficient — it injects its own _MEIPASS into
# LD_LIBRARY_PATH.  We only prepend the bundle dir as a belt-and-suspenders
# fallback for Qt xcb platform plugins on some older distros.
HERE="$(dirname "$(readlink -f "$0")")"
APP_BIN="$HERE/usr/bin"

export LD_LIBRARY_PATH="${APP_BIN}:${APP_BIN}/_internal:${LD_LIBRARY_PATH:-}"

# Let Qt find its platform plugins inside the bundle
export QT_QPA_PLATFORM_PLUGIN_PATH="${APP_BIN}/_internal/PySide6/Qt/plugins/platforms"

exec "$APP_BIN/TDTool" "$@"
